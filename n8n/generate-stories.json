    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ $('Webhook').item.json.body.supabase_url }}/rest/v1/generation_runs?id=eq.{{ $('Webhook').item.json.body.run_id }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $('Webhook').item.json.body.supabase_key }}" },
            { "name": "Authorization", "value": "=Bearer {{ $('Webhook').item.json.body.supabase_key }}" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
